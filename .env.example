# --- Spotify API Authentication ---
# Get these from the Spotify Developer Dashboard (https://developer.spotify.com/dashboard)
SpotifyClientID=your_spotify_client_id 
SpotifyClientSecret=your_spotify_client_secret
# The long-lived token used to generate new access tokens without manual login
SpotifyRefreshToken=your_spotify_refresh_token

# --- File Paths ---
# Local path to the file storing Facebook session/state information
FBStatePath=path_to_your_fb_state_file

# --- Logic & Timing Settings ---
# Timezone offset from UTC (e.g., 8 for PHT/SGT, -5 for EST) 
TimezoneGMTOffset=8
# The hours of the day the bot/app is allowed to run (0-24 is always active)
ActiveHours=8-23
# Minimum duration (in milliseconds) a song must play before it's registered/logged
MinimumPlayTimeMs=60000
# Range (in minutes) for how often the script checks for updates (min-max)
UpdateIntervalRange=10-12
